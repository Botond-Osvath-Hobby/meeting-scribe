@page
@model IndexModel
@{
    ViewData["Title"] = "Meeting Scribe";
}

<section class="hero">
    <p class="eyebrow">AI meeting recap</p>
    <h1>Upload a video. Get Hungarian business notes.</h1>
    <p class="lede">
        Meeting Scribe transcribes Hungarian meeting audio, captures every decision, and writes an executive-ready summary without any logins or databases.
    </p>
</section>

<section class="upload-wrapper">
    <form method="post" enctype="multipart/form-data" class="upload-card" data-progress="meeting">
        <input type="hidden" id="operationId" name="OperationId" value="@Model.OperationId" />
        <div class="file-drop" id="file-drop">
            <input type="file" id="meetingVideo" name="MeetingVideo" accept="video/*,audio/*" required />
            <div class="file-copy">
                <h2>Drag & drop your recording</h2>
                <p>Video: MP4, MOV, MKV, AVI, WEBM · Audio: MP3, WAV, M4A, FLAC, OGG · Max 2 GB</p>
                <button type="button" class="ghost-btn" id="select-file">Browse files</button>
                <p class="file-name" data-default="No file selected" id="file-name">No file selected</p>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <p class="error-banner" id="error-banner" @(string.IsNullOrEmpty(Model.ErrorMessage) ? "hidden" : "")>@Model.ErrorMessage</p>

        <button type="submit" class="primary-btn" id="action-button" data-state="submit">Generate decision summary</button>
    </form>
</section>

<section class="results" id="results" hidden data-has-result="false">
    <!-- Transcript and Notes Card -->
    <div class="result-card" id="transcriptCard" style="display: none;">
        <div class="result-card__header">
            <p class="eyebrow">Stage 2 Complete</p>
            <span class="badge">Timestamped notes</span>
        </div>
        <h2>Transcription ready</h2>
        <ul class="notes-list" data-result="notes">
            @if (Model.Transcript is not null)
            {
                @foreach (var note in Model.Transcript.Notes)
                {
                    <li>@note</li>
                }
            }
        </ul>
    </div>
    
    <!-- Agent Selector Card -->
    <div class="result-card" id="agentCard" style="display: none;">
        <div class="result-card__header">
            <p class="eyebrow">Stage 3</p>
            <span class="badge badge--primary">Choose Agent</span>
        </div>
        <h2>Select summary type</h2>
        
        <div class="agent-selector" id="agentSelector">
            <div class="form-group">
                <label for="agentPreset" class="form-label">
                    <span class="label-icon">🤖</span>
                    Select Agent Type
                </label>
                <select id="agentPreset" class="form-select">
                    @foreach (var preset in Model.AgentPresets)
                    {
                        <option value="@preset.Id" 
                                data-system-prompt="@preset.SystemPrompt" 
                                data-user-prompt="@preset.UserPromptTemplate"
                                data-critical-instruction="@preset.CriticalInstruction"
                                selected="@(preset.Id == "detailed-minutes")">
                            @preset.Name - @preset.Description
                        </option>
                    }
                </select>
            </div>
            
            <div class="form-group">
                <label for="systemPromptInput" class="form-label">
                    <span class="label-icon">⚙️</span>
                    System Prompt
                </label>
                <textarea id="systemPromptInput" name="SystemPrompt" class="form-textarea" rows="6" placeholder="Define the agent's role and behavior...">@(Model.SystemPrompt ?? Models.AgentPresets.DetailedMinutes.SystemPrompt)</textarea>
            </div>
            
            <div class="form-group">
                <label for="userPromptInput" class="form-label">
                    <span class="label-icon">💬</span>
                    User Prompt Template
                </label>
                <textarea id="userPromptInput" name="UserPromptTemplate" class="form-textarea" rows="5" placeholder="Define how to structure the request...">@(Model.UserPromptTemplate ?? Models.AgentPresets.DetailedMinutes.UserPromptTemplate)</textarea>
                <small class="form-hint">Use <code>{transcript}</code> as placeholder for the meeting transcript</small>
            </div>
            
            <div class="form-group">
                <label for="criticalInstructionInput" class="form-label">
                    <span class="label-icon">⚠️</span>
                    Critical Instruction
                </label>
                <textarea id="criticalInstructionInput" name="CriticalInstruction" class="form-textarea" rows="6" placeholder="Critical requirements (language, context handling)...">@(Model.CriticalInstruction ?? Models.AgentPresets.DefaultCriticalInstruction)</textarea>
                <small class="form-hint">ALWAYS applied - controls output language and context inference</small>
            </div>
            
            <input type="hidden" id="transcriptPath" name="TranscriptPath" value="@(Model.Transcript?.TranscriptPath ?? "")" />
            
            <button type="button" id="generateSummary" class="primary-btn" data-initial-state="true">
                ✨ Generate Summary
            </button>
        </div>
    </div>
    
    <!-- Summary Card (hidden by default) -->
    <div class="result-card" id="summaryCard" style="display: none;">
        <div class="result-card__header">
            <p class="eyebrow">Summary Generated</p>
            <span class="badge badge--primary">Business summary</span>
        </div>
        <h2>Decisions & rationale</h2>
        
        <p class="processing-time" id="processingTime" style="display: none;">
            ⏱️ Summarization completed in <span id="durationText"></span>
        </p>
        
        <div class="summary-content" data-result="summary">
            @if (Model.Result is not null)
            {
                @Html.Raw(Model.FormattedSummary)
            }
        </div>
        
        <button type="button" id="regenerateSummary" class="secondary-btn">
            🔄 Regenerate with Different Agent
        </button>
    </div>
</section>

<section class="progress-overlay" id="progress-overlay" hidden aria-hidden="true">
    <div class="progress-card">
        <div class="progress-card__header">
            <p class="eyebrow">Processing meeting</p>
            <h2>Working on your recap</h2>
            <p class="progress-hint">Keep this tab open while we upload, transcribe, and summarize.</p>
        </div>

        <div class="progress-steps">
            <div class="progress-step" data-progress-step="upload">
                <div class="progress-step__header">
                    <span class="progress-step__title">Stage 1: Upload & sanitize video</span>
                    <span class="progress-step__status">Pending</span>
                </div>
                <div class="progress-step__bar"><span></span></div>
                <p>Saving an encrypted temporary copy before deletion.</p>
            </div>
            <div class="progress-step" data-progress-step="transcribe">
                <div class="progress-step__header">
                    <span class="progress-step__title">Stage 2: Hungarian transcription</span>
                    <span class="progress-step__status">Pending</span>
                </div>
                <div class="progress-step__bar"><span></span></div>
                <p>Running Whisper to capture timestamped notes.</p>
            </div>
            <div class="progress-step" data-progress-step="summarize">
                <div class="progress-step__header">
                    <span class="progress-step__title">Stage 3: Decision summary</span>
                    <span class="progress-step__status">Pending</span>
                </div>
                <div class="progress-step__spinner" aria-hidden="true">
                    <span></span>
                </div>
                <div class="progress-step__tokens" id="tokenCounter" style="display: none;">
                    <span class="token-badge">
                        <span id="tokenCount">0</span> tokens
                    </span>
                    <span class="token-details" id="tokenDetails"></span>
                </div>
                <p>Feeding notes into the AI agent.</p>
            </div>
        </div>
    </div>
</section>
