<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MeetingScribe.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MeetingScribe.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="shell">
            <div class="logo">
                <span class="logo-dot"></span>
                <div>
                    <span class="logo-title">Meeting Scribe</span>
                    <span class="logo-caption">Hungarian AI meeting notes</span>
                </div>
            </div>
            <span class="tagline">No logins · No database · Just decisions</span>
        </div>
    </header>

    <main class="shell">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="shell">
            <p class="created-by-text">&copy; @DateTime.UtcNow.Year Meeting Scribe.<br><br><span><a class="created-by" href="https://osvathbotond.com/" target="_blank">Built with ASP.NET Core + Python by Osváth Botond</a></span></p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

